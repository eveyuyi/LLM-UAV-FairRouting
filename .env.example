# Copy this file to `.env` and fill in your real values.

# Optional: let the helper shell script choose the conda environment.
LLM4FAIRROUTING_CONDA_ENV=gpt_academic

# API settings for online workflow runs.
LLM4FAIRROUTING_API_KEY=sk-REPLACE_ME
LLM4FAIRROUTING_API_BASE=http://35.220.164.252:3888/v1
LLM4FAIRROUTING_MODEL=gpt-4o-mini

# Common experiment parameters.
LLM4FAIRROUTING_TIME_SLOTS=0
LLM4FAIRROUTING_NOISE_WEIGHT=0.5
LLM4FAIRROUTING_WINDOW=5
LLM4FAIRROUTING_OFFLINE=false
LLM4FAIRROUTING_SKIP_SOLVER=false

# Optional overrides.
# LLM4FAIRROUTING_OUTPUT_DIR=results
# LLM4FAIRROUTING_CSV=data/seed/daily_demand_events.csv
# LLM4FAIRROUTING_STATIONS=data/seed/drone_station_locations.csv
# LLM4FAIRROUTING_BUILDING_DATA=data/seed/building_information.csv
# LLM4FAIRROUTING_MAX_SOLVER_STATIONS=1
# LLM4FAIRROUTING_DRONE_SPEED=60.0
